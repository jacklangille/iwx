{
  "name": "assets",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "esbuild js/app.js --bundle --outfile=../priv/static/assets/app.js",
    "copy:css": "cp css/*.css ../priv/static/assets/css/",
    "watch:js": "esbuild js/app.js --bundle --outfile=../priv/static/assets/app.js --watch",
    "watch:css": "chokidar \"css/**/*.css\" -c \"cp css/*.css ../priv/static/assets/css/\"",
    "dev": "npm run copy:css && concurrently \"npm run watch:js\" \"npm run watch:css\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "chart.js": "^4.5.1",
    "esbuild": "^0.28.0",
    "maplibre-gl": "^5.24.0"
  },
  "devDependencies": {
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.0.0"
  }
}
